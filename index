<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GreakX — Next-Gen Tech Identity</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #030712;
    --card: #0f172a;
    --border: #1e293b;
    --accent: #38bdf8;
    --accent-glow: rgba(56, 189, 248, 0.3);
    --text-main: #f8fafc;
    --text-dim: #94a3b8;
    --white: #ffffff;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text-main);
    font-family: 'Outfit', sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* AMBIENT BACKGROUND */
  .glow-mesh {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: 
      radial-gradient(circle at 20% 20%, rgba(56, 189, 248, 0.05) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(56, 189, 248, 0.05) 0%, transparent 40%);
    z-index: -1;
  }

  /* NAVIGATION */
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 10%;
    background: rgba(3, 7, 18, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .logo {
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--white);
    text-decoration: none;
  }
  .logo span { color: var(--accent); }

  .nav-cta {
    background: var(--accent);
    color: var(--bg);
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }
  .nav-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px var(--accent-glow);
  }

  /* HERO SECTION */
  .hero {
    padding: 8rem 10% 4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .badge {
    background: rgba(56, 189, 248, 0.1);
    color: var(--accent);
    padding: 0.5rem 1rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 600;
    margin-bottom: 2rem;
    border: 1px solid var(--accent-glow);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .hero h1 {
    font-size: clamp(4rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom, #fff 40%, #64748b);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero p {
    font-size: 1.25rem;
    color: var(--text-dim);
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
  }

  .btn {
    padding: 1rem 2.5rem;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-p { background: var(--white); color: var(--bg); }
  .btn-s { border: 1px solid var(--border); color: var(--white); }
  .btn-p:hover { transform: scale(1.05); }
  .btn-s:hover { background: rgba(255,255,255,0.05); }

  /* PRICE CARD */
  .price-banner {
    margin-top: 4rem;
    background: var(--card);
    border: 1px solid var(--border);
    padding: 2rem;
    border-radius: 24px;
    display: inline-flex;
    align-items: center;
    gap: 2rem;
  }

  .price-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2rem;
    color: var(--accent);
    font-weight: 700;
  }

  /* GRID FEATURES */
  section { padding: 4rem 10%; }
  .section-title { margin-bottom: 3rem; font-size: 2rem; text-align: center; }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .f-card {
    background: var(--card);
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    transition: border 0.3s ease;
  }
  .f-card:hover { border-color: var(--accent); }
  .f-card h3 { margin-bottom: 1rem; color: var(--white); }
  .f-card p { color: var(--text-dim); font-size: 0.95rem; }

  /* ANALYTICS TERMINAL */
  .terminal {
    background: #000;
    border-radius: 12px;
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    max-width: 800px;
    margin: 4rem auto;
  }
  .t-header { display: flex; gap: 6px; margin-bottom: 1rem; }
  .t-dot { width: 12px; height: 12px; border-radius: 50%; }
  .green { color: #4ade80; }
  .blue { color: var(--accent); }

  /* FOOTER */
  footer {
    padding: 4rem 10%;
    border-top: 1px solid var(--border);
    text-align: center;
    background: rgba(15, 23, 42, 0.5);
  }
  .contact-link { color: var(--accent); text-decoration: none; font-weight: 600; }

  @media (max-width: 768px) {
    .hero h1 { font-size: 3.5rem; }
    .price-banner { flex-direction: column; gap: 0.5rem; }
  }
</style>
</head>
